#!/bin/bash
# Optional trampoline for developers who hit wrong-toolchain issues
# (chocolatey cargo on Windows, stale system rust on Linux, etc.).
# Routes through the globally installed `soldr` so `rustup which`
# picks the rustup-managed toolchain. `--no-cache` keeps soldr's
# RUSTC_WRAPPER / zccache path off so this matches bare-cargo
# semantics.
exec soldr --no-cache cargo "$@"
