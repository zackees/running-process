#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --no-skip)
      export RUNNING_PROCESS_REQUIRE_NATIVE_DEBUGGER_SYMBOLS=1
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [ -x "$ROOT_DIR/.venv/Scripts/python.exe" ]; then
  PYTHON="$ROOT_DIR/.venv/Scripts/python.exe"
elif [ -x "$ROOT_DIR/.venv/bin/python" ]; then
  PYTHON="$ROOT_DIR/.venv/bin/python"
else
  echo "repo venv python not found" >&2
  exit 1
fi

export RUNNING_PROCESS_TEST_TIMEOUT_SECONDS=10

exec uv run --no-editable running-process --timeout=10 -- "$PYTHON" -m ci.test "${ARGS[@]}"
