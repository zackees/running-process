target/
dist/
dist-dev/
linux/*.whl
linux/.incoming-*/
*.pyd
*.so
*.dll
*.dylib
# Never ignore anything under `vendor/` — vendored bytes are
# operator-controlled, committed via Git LFS for the binary ones, and
# always part of the source tree (see `vendor/win32/conpty/README.md`).
# Single-rule exception so future `vendor/<platform>/` directories are
# covered without revisiting this file.
!vendor/**
__pycache__/
.pytest_cache/
.ruff_cache/
.venv/
.mypy_cache/
.coverage
htmlcov/
coverage-python.xml
coverage-rust.lcov

*.pdb
*.log
logs/
.cargo/
.rustup/
.loop/
.claude/
.extern-repos/
src/running_process/assets/daemon-trampoline
src/running_process/assets/daemon-trampoline.exe

# clud project settings
!.clud/
!.clud/settings.json
